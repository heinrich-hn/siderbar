{
  "manifest_version": 3,
  "name": "Siderbar",
  "version": "2.1",
  "description": "Multi-provider AI assistant — Translate, Chat, and Code in a sidebar panel",
  "action": {
    "default_title": "Siderbar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "worker.js"
  },
  "commands": {
    "toggle-translate": {
      "suggested_key": { "default": "Alt+T" },
      "description": "Switch to Translate tab"
    },
    "toggle-chat": {
      "suggested_key": { "default": "Alt+C" },
      "description": "Switch to Chat tab"
    },
    "toggle-code": {
      "suggested_key": { "default": "Alt+X" },
      "description": "Switch to Code tab"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ]
}